# PSPAH server environment variables.
# Copy to `.env` and fill in real values. NEVER commit the populated `.env`.

# ─── Database ──────────────────────────────────────────────────────────────────
# Either provide a full DATABASE_URL (preferred) or the discrete SUPABASE_* vars.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Used as the email logo host and as a Supabase pooler username prefix when
# DATABASE_URL is not set.
SUPABASE_PROJECT_ID=
SUPABASE_PASSWORD=
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_DBNAME=postgres

# Connection pool tuning (optional). Defaults shown.
DB_POOL_MIN_CONN=2
DB_POOL_MAX_CONN=20
DB_STATEMENT_TIMEOUT_MS=10000

# ─── Supabase Storage (resume uploads, image URLs) ────────────────────────────
SUPABASE_SECRET_KEY=
# Resilience tuning for outbound Supabase Storage calls (defaults shown).
# Retries cover transient timeouts, network errors, HTTP 429, and 5xx.
# The circuit breaker opens after N consecutive failures and fast-fails
# subsequent requests for the recovery window before allowing a probe.
SUPABASE_TIMEOUT_SEC=15
SUPABASE_MAX_ATTEMPTS=3
SUPABASE_RETRY_BACKOFF_SEC=0.3
SUPABASE_MAX_BACKOFF_SEC=2
SUPABASE_CB_FAILURE_THRESHOLD=3
SUPABASE_CB_OPEN_SEC=20

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
COMPANY_EMAIL=ops@example.com
# Resilience tuning for Resend email sends (defaults shown).
# Per-call timeout wraps the SDK call; retries cover timeout/connection errors.
RESEND_TIMEOUT_SEC=8
RESEND_MAX_ATTEMPTS=3
RESEND_RETRY_BACKOFF_SEC=0.3
RESEND_MAX_BACKOFF_SEC=2
RESEND_CB_FAILURE_THRESHOLD=3
RESEND_CB_OPEN_SEC=20

# ─── hCaptcha ──────────────────────────────────────────────────────────────────
HCAPTCHA_SECRET_KEY=
# Set ALLOW_CAPTCHA_BYPASS=true ONLY for local dev / tests.
ALLOW_CAPTCHA_BYPASS=false
# Resilience tuning for hCaptcha siteverify calls (defaults shown).
# When the breaker is open, verification fails as `network_error` so the
# /api/verify-captcha route returns HTTP 502 instead of hanging clients.
HCAPTCHA_TIMEOUT_SEC=5
HCAPTCHA_MAX_ATTEMPTS=3
HCAPTCHA_RETRY_BACKOFF_SEC=0.25
HCAPTCHA_MAX_BACKOFF_SEC=1.5
HCAPTCHA_CB_FAILURE_THRESHOLD=3
HCAPTCHA_CB_OPEN_SEC=20

# ─── Newsletter unsubscribe HMAC (required in production) ──────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NEWSLETTER_UNSUBSCRIBE_SECRET=
NEWSLETTER_UNSUBSCRIBE_BASE_URL=

# ─── HTTP / hosting ────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins. Empty → use built-in defaults.
CORS_ORIGINS=
# Comma-separated list of extra trusted Host headers.
ALLOWED_HOSTS=
# Default true. Set false for plain-HTTP local dev.
ENABLE_HTTPS_REDIRECT=true
# Whether to honour X-Forwarded-* headers when computing the client IP.
TRUST_PROXY_HEADERS=true
# Comma-separated trusted proxy IPs/CIDRs allowed to supply X-Forwarded-For.
# Use exact platform proxy ranges in production; '*' is supported only when the
# app is unreachable except through a trusted edge that overwrites the header.
TRUSTED_PROXY_IPS=127.0.0.1,::1

# ─── Resume uploads ────────────────────────────────────────────────────────────
MAX_RESUME_SIZE_BYTES=5242880

# ─── Blog ──────────────────────────────────────────────────────────────────────
BLOG_CACHE_MAX_AGE=300

# ─── Observability ─────────────────────────────────────────────────────────────
# Optional. If SENTRY_DSN is set, errors are reported to Sentry.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Log output: "text" (human-readable) or "json" (single-line for log aggregators).
LOG_FORMAT=text
LOG_LEVEL=INFO
