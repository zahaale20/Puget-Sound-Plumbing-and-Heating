@startuml
!include <C4/C4_Container>

LAYOUT_WITH_LEGEND()

title Container Diagram: PSPAH Digital Ecosystem

' Minor refresh to trigger CI/CD deployment

Person(customers, "Customers", "Home or business owner in the Puget Sound area.")
Person(pspah, "Puget Sound Plumbing and Heating", "Local plumbing and heating service provider.")

Enterprise_Boundary(c0, "External Support Partners") {
    Person_Ext(kingit, "King IT Consulting", "Consulting firm providing business strategy and technical growth advice.")
    Person_Ext(cavo, "Cavo Studio", "Software development agency responsible for designing and building the website.")
}

System_Boundary(pspah_system, "PSPAH Website") {
    Container(static_content, "Static Content", "Directory", "Hosts built HTML, Tailwind CSS, and Javascript assets.")
    Container(ui, "User Interface", "React", "Multi-page application providing plumbing-related functionality and lead capture.")
    Container(backend, "Backend", "Python, FastAPI", "Provides plumbing-related functionality via a JSON/HTTP API.")
    ContainerDb(db, "Database", "Supabase [PostgreSQL]", "Stores customer information, leads, and service data.")
}

' User/Staff Interactions
Rel(customers, static_content, "Loads the UI from", "HTTPS")
Rel(customers, ui, "Interacts with and navigates", "UI/UX")
Rel(pspah, ui, "Reviews content and media assets", "UI/UX")

' Partner Interactions
Rel(cavo, ui, "Develops")
Rel(cavo, backend, "Develops")
Rel(cavo, db, "Develops")
Rel(kingit, ui, "Uploads professional media and updates requirements")

' Internal System Flux
Rel(ui, backend, "Makes API calls to", "JSON/HTTPS")
Rel(backend, db, "Reads from and writes to", "SQL/HTTPS")
Rel(static_content, ui, "Delivers assets to", "HTTPS")

' Business Value Loop
Rel(pspah, customers, "Provides plumbing and heating services", "In-Person/Phone")
Rel(kingit, pspah, "Advises on business strategy and technical growth")
Rel(cavo, pspah, "Delivers the finished website and provides ongoing technical support")
Rel(kingit, cavo, "Updates requirements, suggests website design changes, and sends professional media")
Rel(pspah, kingit, "Suggests website design changes")

@enduml