{
	"name": "pspah-website",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"prebuild": "node scripts/generate-sitemap.mjs",
		"build": "vite build && npm run seo:prerender && npm run seo:audit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"seo:prerender": "node scripts/prerender-static.mjs",
		"seo:audit": "node scripts/seo-audit.mjs",
		"analyze": "npm run build && npx vite-bundle-visualizer",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"preview": "vite preview"
	},
	"dependencies": {
		"@fortawesome/fontawesome-free": "^7.1.0",
		"@hcaptcha/react-hcaptcha": "^2.0.2",
		"@tailwindcss/vite": "^4.1.13",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"framer-motion": "^12.23.24",
		"lucide-react": "^0.544.0",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-helmet-async": "^3.0.0",
		"react-icons": "^5.5.0",
		"react-router-dom": "^7.12.1",
		"tailwindcss": "^4.1.13"
	},
	"devDependencies": {
		"@eslint/js": "^9.36.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@types/react": "^19.1.13",
		"@types/react-dom": "^19.1.9",
		"@vitejs/plugin-react": "^5.0.3",
		"@vitest/coverage-v8": "^3.2.4",
		"eslint": "^9.36.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"globals": "^16.4.0",
		"jsdom": "^26.1.0",
		"prettier": "^3.6.2",
		"vite": "^7.1.12",
		"vitest": "^3.2.4"
	},
	"overrides": {
		"ajv": "^6.14.0",
		"brace-expansion": "^1.1.13",
		"flatted": "^3.4.2",
		"js-yaml": "^4.1.1",
		"minimatch": "^9.0.5",
		"picomatch": "^4.0.4",
		"rollup": "^4.59.0",
		"tar": "^7.5.11"
	}
}
