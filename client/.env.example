# PSPAH client environment variables.
# Copy to `.env` and fill in real values. NEVER commit the populated `.env`.

# Public Supabase storage bucket base URL (used by getImageUrl()).
VITE_SUPABASE_STORAGE_URL=https://your-project.supabase.co

# Backend API base URL. Leave empty to use the dev proxy in vite.config.js.
VITE_API_BASE_URL=

# hCaptcha site key (public — paired with HCAPTCHA_SECRET_KEY on the server).
VITE_HCAPTCHA_SITE_KEY=
