{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "pugetsoundplumbing.com" }
      ],
      "destination": "https://www.pugetsoundplumbing.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}   